{
  "manifest_version": 3,
  "name": "ActBlue Session Keepalive",
  "version": "0.2.0",
  "description": "Keeps an active ActBlue dashboard session warm with a periodic credentialed request, so idle gaps don't force a re-login.",
  "permissions": ["alarms", "storage", "notifications"],
  "host_permissions": ["https://*.actblue.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ActBlue Session Keepalive"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
