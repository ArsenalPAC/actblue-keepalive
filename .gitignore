# Build artifacts are ignored by default...
*.zip
*.crx
*.pem
*.sha256

# ...except the shipped package, which is committed on purpose so it can be
# downloaded straight from the repo.
!dist/actblue-keepalive.zip
!dist/actblue-keepalive.zip.sha256

# Dependencies / build output
node_modules/

# Local editor / OS cruft
.DS_Store
Thumbs.db
.vscode/
.idea/

# Local-only working notes and overrides, never part of the deliverable
.scratch/
*.local.md
